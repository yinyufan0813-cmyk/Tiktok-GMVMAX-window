.page {
  min-height: 100vh;
  padding: 28rpx;
  background: #0f172a;
  color: #f8fafc;
}

.header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  line-height: 1.1;
  font-weight: 800;
}

.sub-title {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 22rpx;
}

.status {
  max-width: 360rpx;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: right;
}

.status.loading {
  color: #38bdf8;
}

.status.error-state {
  color: #fecaca;
}

.summary {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.tile,
.mini-tile,
.card,
.empty,
.error {
  border: 1rpx solid #334155;
  background: #111827;
  border-radius: 14rpx;
}

.tile {
  padding: 18rpx;
  min-width: 0;
}

.label {
  display: block;
  color: #94a3b8;
  font-size: 21rpx;
  margin-bottom: 8rpx;
}

.metric {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-width: 0;
}

.value {
  font-size: 30rpx;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.mini-tile .value {
  font-size: 27rpx;
}

.diff {
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 20rpx;
  overflow-wrap: anywhere;
}

.arrow {
  font-size: 23rpx;
  font-weight: 900;
}

.up {
  color: #22c55e;
}

.down {
  color: #ef4444;
}

.flat {
  color: #94a3b8;
}

.spend {
  color: #fbbf24;
}

.gmv {
  color: #38bdf8;
}

.roi {
  color: #a78bfa;
}

.total {
  color: #e5e7eb;
}

.cards {
  display: grid;
  gap: 18rpx;
}

.card {
  padding: 20rpx;
}

.account-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.account-name {
  flex: 0 0 auto;
  max-width: 280rpx;
  font-size: 30rpx;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.campaign {
  flex: 1;
  color: #94a3b8;
  font-size: 20rpx;
  line-height: 1.35;
  text-align: right;
  overflow-wrap: anywhere;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.mini-tile {
  padding: 16rpx;
  min-width: 0;
}

.empty,
.error {
  padding: 28rpx;
  color: #94a3b8;
  font-size: 25rpx;
  line-height: 1.5;
}

.error {
  color: #fecaca;
}

.error-title {
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.error-text {
  margin-bottom: 18rpx;
}

.refresh-btn {
  margin: 0;
  width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 10rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 24rpx;
}
